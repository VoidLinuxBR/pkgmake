        "class": "USER",
        "type": "REG_SZ",
        "data": "homepage"
    },
    {
        "keyname": "Software\ePolicies\eMozilla\eFirefox\eHomepage",
        "valuename": "URL",
        "class": "USER",
        "type": "REG_SZ",
